<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Required on API 30+ to query for browser apps that handle HTTPS URLs -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>

    <application
        android:label="FiberSocial"
        android:theme="@style/Theme.FiberSocial">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!--
            AppAuth's RedirectUriReceiverActivity is merged in from the appauth library
            with the fibersocial:// scheme via the appAuthRedirectScheme manifest placeholder.
            It receives the OAuth callback and delivers the result back to the launcher.
        -->
    </application>
</manifest>
